# Zkopiruj tento soubor jako .env a vypln klice
# .env je v .gitignore - nikdy se nepushne na github

# ENTSO-E Transparency Platform API token
# Ziskej na https://transparency.entsoe.eu -> My Account Settings -> Web API Security Token
ENTSOE_TOKEN=tady_tvuj_entsoe_token

# Anthropic Claude API key
# Ziskej na https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=tady_tvuj_anthropic_key
